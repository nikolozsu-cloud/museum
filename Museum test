<script>
// ── CURSOR ──
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursor-ring');
let mx = 0, my = 0, rx = 0, ry = 0;

document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cursor.style.left = mx + 'px';
  cursor.style.top = my + 'px';
});

function animateRing() {
  rx += (mx - rx) * .12;
  ry += (my - ry) * .12;
  ring.style.left = rx + 'px';
  ring.style.top = ry + 'px';
  requestAnimationFrame(animateRing);
}
animateRing();

document.querySelectorAll('a, button, .art-card').forEach(el => {
  el.addEventListener('mouseenter', () => {
    cursor.style.width = '20px';
    cursor.style.height = '20px';
    ring.style.width = '60px';
    ring.style.height = '60px';
  });
  el.addEventListener('mouseleave', () => {
    cursor.style.width = '10px';
    cursor.style.height = '10px';
    ring.style.width = '36px';
    ring.style.height = '36px';
  });
});

// ── BACKGROUND PARTICLE CANVAS ──
(function() {
  const canvas = document.getElementById('hero-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, particles = [];

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  class Particle {
    constructor() { this.reset(); }
    reset() {
      this.x = Math.random() * W;
      this.y = Math.random() * H;
      this.r = Math.random() * 1.2 + .2;
      this.vx = (Math.random() - .5) * .3;
      this.vy = (Math.random() - .5) * .3;
      this.alpha = Math.random() * .4 + .1;
      this.gold = Math.random() > .7;
    }
    update() {
      this.x += this.vx; this.y += this.vy;
      if (this.x < 0 || this.x > W || this.y < 0 || this.y > H) this.reset();
    }
    draw() {
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.r, 0, Math.PI*2);
      ctx.fillStyle = this.gold
        ? `rgba(201,168,76,${this.alpha})`
        : `rgba(240,236,228,${this.alpha * .5})`;
      ctx.fill();
    }
  }

  for (let i = 0; i < 160; i++) particles.push(new Particle());

  // Nebula blobs
  function drawNebula(t) {
    const blobs = [
      { x: W*.75, y: H*.35, r: 300, c1: 'rgba(201,168,76,.04)', c2: 'transparent' },
      { x: W*.2, y: H*.6, r: 250, c1: 'rgba(180,60,20,.05)', c2: 'transparent' },
      { x: W*.9, y: H*.8, r: 200, c1: 'rgba(40,80,120,.06)', c2: 'transparent' },
    ];
    blobs.forEach(b => {
      const px = b.x + Math.sin(t*.0003) * 30;
      const py = b.y + Math.cos(t*.0004) * 20;
      const g = ctx.createRadialGradient(px, py, 0, px, py, b.r);
      g.addColorStop(0, b.c1); g.addColorStop(1, b.c2);
      ctx.fillStyle = g;
      ctx.beginPath();
      ctx.arc(px, py, b.r, 0, Math.PI*2);
      ctx.fill();
    });
  }

  let t = 0;
  function loop() {
    t++;
    ctx.clearRect(0, 0, W, H);
    drawNebula(t);
    particles.forEach(p => { p.update(); p.draw(); });
    requestAnimationFrame(loop);
  }
  loop();
})();

// ── 3D CARD TILT ──
document.querySelectorAll('.art-card-3d').forEach(card => {
  card.addEventListener('mousemove', e => {
    const rect = card.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width - .5;
    const y = (e.clientY - rect.top) / rect.height - .5;
    card.style.transform = `perspective(800px) rotateY(${x*14}deg) rotateX(${-y*10}deg) translateZ(8px)`;
  });
  card.addEventListener('mouseleave', () => {
    card.style.transform = 'perspective(800px) rotateY(0) rotateX(0) translateZ(0)';
  });
});

// ── 3D ART VIEWER CANVAS ──
(function() {
  const canvas = document.getElementById('art-viewer-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, angle = 0, currentArt = 0, targetArt = 0, transition = 0;

  const artworks = [
    {
      name: 'Crimson Vestige', artist: 'Mara Solano — 2024',
      medium: 'Oil on Canvas', dims: '120 × 90 cm', year: '2024',
      price: '$12,400', desc: 'A sweeping meditation on loss and memory, "Crimson Vestige" draws the eye through layers of deep red and burnt sienna, evoking the ephemeral nature of what we leave behind.',
      drawFn: function(ctx, W, H, t) {
        // Background
        const bg = ctx.createRadialGradient(W*.4, H*.35, 0, W*.5, H*.5, W*.7);
        bg.addColorStop(0, '#5a1010');
        bg.addColorStop(.4, '#2a0808');
        bg.addColorStop(1, '#0a0504');
        ctx.fillStyle = bg;
        ctx.fillRect(0,0,W,H);
        // Moving shapes
        ctx.save();
        ctx.globalAlpha = .6 + Math.sin(t*.02)*.1;
        const g1 = ctx.createRadialGradient(W*(.35+Math.sin(t*.015)*.05), H*.4, 0, W*.4, H*.4, W*.4);
        g1.addColorStop(0, 'rgba(180,40,20,.8)');
        g1.addColorStop(.5, 'rgba(100,20,10,.4)');
        g1.addColorStop(1, 'transparent');
        ctx.fillStyle = g1;
        ctx.beginPath(); ctx.ellipse(W*.4, H*.4, W*.35, H*.45, -.3, 0, Math.PI*2); ctx.fill();
        ctx.restore();
        // Light spot
        ctx.save(); ctx.globalAlpha = .3 + Math.sin(t*.025)*.05;
        const g2 = ctx.createRadialGradient(W*.55, H*.3, 0, W*.55, H*.3, W*.2);
        g2.addColorStop(0, 'rgba(255,180,100,.5)'); g2.addColorStop(1, 'transparent');
        ctx.fillStyle = g2;
        ctx.beginPath(); ctx.arc(W*.55, H*.3, W*.2, 0, Math.PI*2); ctx.fill();
        ctx.restore();
        // Brushstroke lines
        ctx.save(); ctx.globalAlpha = .12;
        for(let i=0; i<12; i++) {
          ctx.beginPath();
          ctx.moveTo(0, H*(i/12) + Math.sin(t*.01+i)*.8);
          ctx.lineTo(W, H*(i/12+.08) + Math.cos(t*.008+i)*.8);
          ctx.strokeStyle = `rgba(255,${120+i*8},${50+i*4},.5)`;
          ctx.lineWidth = 8 - i*.4;
          ctx.stroke();
        }
        ctx.restore();
      }
    },
    {
      name: 'Golden Meridian', artist: 'Kai Nishimura — 2023',
      medium: 'Acrylic on Board', dims: '80 × 80 cm', year: '2023',
      price: '$7,800', desc: 'Nishimura explores the intersection of celestial geometry and earthbound warmth. The central solar orb pulses with an interior light that seems almost kinetic.',
      drawFn: function(ctx, W, H, t) {
        ctx.fillStyle = '#08080a'; ctx.fillRect(0,0,W,H);
        // Horizon
        const hz = ctx.createLinearGradient(0, H*.6, 0, H);
        hz.addColorStop(0, '#1c1408'); hz.addColorStop(1, '#0a0904');
        ctx.fillStyle = hz; ctx.fillRect(0, H*.6, W, H*.4);
        // Sun glow
        const sunX = W*.5, sunY = H*.45 + Math.sin(t*.018)*8;
        const glow = ctx.createRadialGradient(sunX, sunY, 0, sunX, sunY, W*.45);
        glow.addColorStop(0,'rgba(255,220,80,.9)'); glow.addColorStop(.2,'rgba(200,140,20,.5)'); glow.addColorStop(.5,'rgba(120,70,10,.2)'); glow.addColorStop(1,'transparent');
        ctx.fillStyle = glow; ctx.beginPath(); ctx.arc(sunX, sunY, W*.45, 0, Math.PI*2); ctx.fill();
        // Sun disk
        ctx.save(); ctx.globalAlpha = .95;
        const sd = ctx.createRadialGradient(sunX, sunY, 0, sunX, sunY, W*.1);
        sd.addColorStop(0,'rgba(255,240,160,1)'); sd.addColorStop(.6,'rgba(220,160,20,1)'); sd.addColorStop(1,'rgba(180,100,10,1)');
        ctx.fillStyle = sd; ctx.beginPath(); ctx.arc(sunX, sunY, W*.1, 0, Math.PI*2); ctx.fill();
        ctx.restore();
        // Rings
        for(let i=1; i<=4; i++) {
          ctx.beginPath(); ctx.arc(sunX, sunY, W*(.1+i*.07), 0, Math.PI*2);
          ctx.strokeStyle = `rgba(200,160,40,${.15/i})`; ctx.lineWidth = 1; ctx.stroke();
        }
        // Reflection
        ctx.save(); ctx.globalAlpha = .3;
        const rf = ctx.createLinearGradient(sunX-20, H*.6, sunX+20, H);
        rf.addColorStop(0,'rgba(220,160,30,.6)'); rf.addColorStop(1,'transparent');
        ctx.fillStyle = rf; ctx.fillRect(sunX-12, H*.6, 24, H*.4);
        ctx.restore();
      }
    },
    {
      name: 'Umbra Nocturne', artist: 'T. Beaumont — 2022',
      medium: 'Oil on Canvas', dims: '100 × 140 cm', year: '2022',
      price: '$15,600', desc: 'Beaumont\'s masterful chiaroscuro conjures a world between waking and sleep. Shadow shapes the space as much as light, and the viewer is implicated in the mystery.',
      drawFn: function(ctx, W, H, t) {
        ctx.fillStyle = '#06040a'; ctx.fillRect(0,0,W,H);
        // Purple void
        const vd = ctx.createRadialGradient(W*.5, H*.4, 0, W*.5, H*.5, W*.6);
        vd.addColorStop(0,'rgba(80,20,120,.4)'); vd.addColorStop(.5,'rgba(30,8,50,.3)'); vd.addColorStop(1,'transparent');
        ctx.fillStyle = vd; ctx.beginPath(); ctx.arc(W*.5, H*.4, W*.6, 0, Math.PI*2); ctx.fill();
        // Moon
        const moonX = W*(.5+Math.sin(t*.01)*.03), moonY = H*(.28+Math.sin(t*.008)*.02);
        const moon = ctx.createRadialGradient(moonX, moonY, 0, moonX, moonY, W*.09);
        moon.addColorStop(0,'rgba(240,230,210,1)'); moon.addColorStop(.7,'rgba(200,190,170,.9)'); moon.addColorStop(1,'transparent');
        ctx.fillStyle = moon; ctx.beginPath(); ctx.arc(moonX, moonY, W*.09, 0, Math.PI*2); ctx.fill();
        // Clouds / shapes
        ctx.save(); ctx.globalAlpha = .18;
        for(let i=0;i<5;i++) {
          ctx.beginPath();
          const cx2 = W*(.1+i*.2), cy2 = H*(.5+Math.sin(t*.005+i)*.1);
          ctx.ellipse(cx2, cy2, W*.18, H*.08, i*.3, 0, Math.PI*2);
          ctx.fillStyle = `rgba(40,15,70,.8)`; ctx.fill();
        }
        ctx.restore();
        // Stars
        ctx.save(); ctx.globalAlpha = 1;
        for(let i=0;i<50;i++) {
          const sx = (Math.sin(i*17.3)*W*.5+W*.5);
          const sy = (Math.cos(i*13.7)*H*.35+H*.25);
          const sa = .3+Math.sin(t*.05+i)*.3;
          ctx.beginPath(); ctx.arc(sx, sy, .8, 0, Math.PI*2);
          ctx.fillStyle = `rgba(240,220,180,${sa})`; ctx.fill();
        }
        ctx.restore();
      }
    }
  ];

  function resize() {
    const parent = canvas.parentElement;
    const size = Math.min(parent.clientWidth, parent.clientHeight || 500);
    canvas.width = size; canvas.height = size;
    W = size; H = size;
  }
  resize();
  window.addEventListener('resize', resize);

  let t = 0;
  function loop() {
    t++;
    if (!W || !H) { requestAnimationFrame(loop); return; }

    ctx.clearRect(0,0,W,H);

    // Frame / canvas border effect
    ctx.save();
    ctx.shadowColor = 'rgba(0,0,0,.8)';
    ctx.shadowBlur = 40;
    ctx.fillStyle = '#000';
    ctx.fillRect(0,0,W,H);
    ctx.restore();

    // Draw artwork with slight perspective warp
    const wobble = Math.sin(t * .008) * 2;
    ctx.save();
    ctx.translate(W*.5, H*.5);
    ctx.rotate(wobble * .003);
    ctx.translate(-W*.5, -H*.5);
    artworks[currentArt].drawFn(ctx, W, H, t);
    ctx.restore();

    // Frame overlay
    ctx.save();
    // Inner vignette
    const vg = ctx.createRadialGradient(W*.5,H*.5,W*.25,W*.5,H*.5,W*.75);
    vg.addColorStop(0,'transparent'); vg.addColorStop(1,'rgba(0,0,0,.5)');
    ctx.fillStyle = vg; ctx.fillRect(0,0,W,H);
    // Gold frame
    ctx.strokeStyle = 'rgba(201,168,76,.5)'; ctx.lineWidth = 6;
    ctx.strokeRect(16,16,W-32,H-32);
    ctx.strokeStyle = 'rgba(201,168,76,.15)'; ctx.lineWidth = 1;
    ctx.strokeRect(24,24,W-48,H-48);
    ctx.restore();

    requestAnimationFrame(loop);
  }
  loop();

  window.switchArtwork = function(idx) {
    currentArt = idx;
    const a = artworks[idx];
    document.getElementById('viewerTitle').textContent = a.name;
    document.getElementById('viewerArtist').textContent = a.artist;
    document.getElementById('viewerDesc').textContent = a.desc;
    document.getElementById('viewerMedium').textContent = a.medium;
    document.getElementById('viewerDims').textContent = a.dims;
    document.getElementById('viewerYear').textContent = a.year;
    document.getElementById('viewerPrice').innerHTML = `${a.price} <span>USD · Free shipping</span>`;
    document.getElementById('viewerAddBtn').onclick = () => addToCart(a.name, a.price);
    document.querySelectorAll('.view-btn').forEach((b,i) => b.classList.toggle('active', i===idx));
  };
})();

// ── ABOUT CANVAS ──
(function() {
  const canvas = document.getElementById('about-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;

  function resize() {
    const r = canvas.getBoundingClientRect();
    W = canvas.width = r.width || 400;
    H = canvas.height = r.height || 400;
  }
  setTimeout(resize, 100);
  window.addEventListener('resize', () => setTimeout(resize, 100));

  let t = 0;
  const nodes = Array.from({length:24}, (_,i) => ({
    x: Math.random(), y: Math.random(),
    vx: (Math.random()-.5)*.001, vy: (Math.random()-.5)*.001,
    r: Math.random()*3+1.5,
    gold: i < 6
  }));

  function loop() {
    t++;
    if (!W || !H) { requestAnimationFrame(loop); return; }
    ctx.clearRect(0,0,W,H);

    // Background
    ctx.fillStyle = '#0c0a09'; ctx.fillRect(0,0,W,H);

    // Ambient glow
    const ag = ctx.createRadialGradient(W*.5,H*.5,0,W*.5,H*.5,W*.5);
    ag.addColorStop(0,'rgba(201,168,76,.04)'); ag.addColorStop(1,'transparent');
    ctx.fillStyle=ag; ctx.fillRect(0,0,W,H);

    // Update nodes
    nodes.forEach(n => {
      n.x += n.vx + Math.sin(t*.005+n.y*10)*.0005;
      n.y += n.vy + Math.cos(t*.004+n.x*10)*.0005;
      if(n.x<0) n.x=1; if(n.x>1) n.x=0;
      if(n.y<0) n.y=1; if(n.y>1) n.y=0;
    });

    // Draw connections
    nodes.forEach((a,i) => {
      nodes.slice(i+1).forEach(b => {
        const dx=(a.x-b.x)*W, dy=(a.y-b.y)*H;
        const dist=Math.sqrt(dx*dx+dy*dy);
        if(dist < W*.22) {
          ctx.beginPath();
          ctx.moveTo(a.x*W, a.y*H);
          ctx.lineTo(b.x*W, b.y*H);
          const alpha=(1-dist/(W*.22))*.15;
          ctx.strokeStyle=(a.gold||b.gold)?`rgba(201,168,76,${alpha})`:`rgba(240,236,228,${alpha*.5})`;
          ctx.lineWidth=.8;
          ctx.stroke();
        }
      });
    });

    // Draw nodes
    nodes.forEach(n => {
      ctx.beginPath();
      ctx.arc(n.x*W, n.y*H, n.r, 0, Math.PI*2);
      ctx.fillStyle = n.gold ? 'rgba(201,168,76,.7)' : 'rgba(240,236,228,.25)';
      ctx.fill();
    });

    // Decorative circle
    ctx.save();
    ctx.strokeStyle = 'rgba(201,168,76,.08)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.arc(W*.5,H*.5,W*.4,0,Math.PI*2); ctx.stroke();
    ctx.beginPath(); ctx.arc(W*.5,H*.5,W*.25,0,Math.PI*2); ctx.stroke();
    ctx.restore();

    requestAnimationFrame(loop);
  }
  loop();
})();

// ── SCROLL REVEAL ──
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: .12 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ── CART ──
let cartCount = 0;
function addToCart(name, price) {
  cartCount++;
  document.getElementById('cartCount').textContent = cartCount;
  const badge = document.getElementById('cartBadge');
  badge.classList.add('show');
  setTimeout(() => badge.classList.remove('show'), 3000);
  const toast = document.getElementById('toast');
  document.getElementById('toastMsg').textContent = `"${name}" added — ${price}`;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 3500);
}

// ── NEWSLETTER ──
function subscribeNewsletter() {
  const email = document.getElementById('newsletterEmail').value;
  if (!email || !email.includes('@')) return;
  const toast = document.getElementById('toast');
  document.getElementById('toastMsg').textContent = 'Welcome to the inner circle.';
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 3500);
  document.getElementById('newsletterEmail').value = '';
}

// ── SMOOTH NAV ──
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const target = document.querySelector(a.getAttribute('href'));
    if(target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth' }); }
  });
});
