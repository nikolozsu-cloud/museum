<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OVUM — Art Gallery & Shop</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Syncopate:wght@400;700&family=DM+Sans:wght@300;400&display=swap');

  :root {
    --ink: #0a0806;
    --bone: #f0ece4;
    --gold: #c9a84c;
    --gold-light: #e8c87a;
    --ember: #e05c2a;
    --slate: #1c1916;
    --fog: rgba(240,236,228,0.06);
    --glow: rgba(201,168,76,0.15);
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--ink);
    color: var(--bone);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
    cursor: none;
  }

  /* ── CUSTOM CURSOR ── */
  #cursor {
    position: fixed; top: 0; left: 0; z-index: 9999;
    width: 10px; height: 10px;
    background: var(--gold);
    border-radius: 50%;
    pointer-events: none;
    transform: translate(-50%,-50%);
    transition: transform .12s ease, width .25s ease, height .25s ease, background .25s ease;
    mix-blend-mode: difference;
  }
  #cursor-ring {
    position: fixed; top: 0; left: 0; z-index: 9998;
    width: 36px; height: 36px;
    border: 1px solid rgba(201,168,76,.5);
    border-radius: 50%;
    pointer-events: none;
    transform: translate(-50%,-50%);
    transition: transform .25s ease, width .3s ease, height .3s ease, opacity .3s;
  }
  body:hover #cursor-ring { opacity: 1; }

  /* ── CANVAS ── */
  #hero-canvas {
    position: fixed; top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: .55;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 28px 60px;
    background: linear-gradient(to bottom, rgba(10,8,6,.9) 0%, transparent 100%);
    backdrop-filter: blur(0px);
  }
  .nav-logo {
    font-family: 'Syncopate', sans-serif;
    font-size: .85rem; font-weight: 700;
    letter-spacing: .35em;
    color: var(--bone);
    text-decoration: none;
  }
  .nav-logo span { color: var(--gold); }
  .nav-links { display: flex; gap: 40px; list-style: none; }
  .nav-links a {
    font-family: 'DM Sans', sans-serif;
    font-size: .75rem; font-weight: 400;
    letter-spacing: .18em; text-transform: uppercase;
    color: rgba(240,236,228,.6);
    text-decoration: none;
    transition: color .3s;
    position: relative;
  }
  .nav-links a::after {
    content: ''; position: absolute; bottom: -4px; left: 0;
    width: 0; height: 1px; background: var(--gold);
    transition: width .3s ease;
  }
  .nav-links a:hover { color: var(--bone); }
  .nav-links a:hover::after { width: 100%; }
  .nav-cta {
    font-family: 'Syncopate', sans-serif;
    font-size: .65rem; font-weight: 700; letter-spacing: .2em;
    color: var(--ink);
    background: var(--gold);
    padding: 10px 24px;
    text-decoration: none;
    transition: background .3s, transform .2s;
  }
  .nav-cta:hover { background: var(--gold-light); transform: translateY(-1px); }

  /* ── HERO ── */
  #hero {
    position: relative; z-index: 1;
    min-height: 100vh;
    display: flex; flex-direction: column; align-items: flex-start; justify-content: center;
    padding: 0 60px;
    overflow: hidden;
  }
  .hero-eyebrow {
    font-family: 'Syncopate', sans-serif;
    font-size: .62rem; letter-spacing: .45em; text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp .8s .3s ease forwards;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(4.5rem, 9vw, 10rem);
    font-weight: 300; line-height: .92;
    letter-spacing: -.02em;
    max-width: 800px;
    opacity: 0;
    animation: fadeUp .9s .5s ease forwards;
  }
  .hero-title em { font-style: italic; color: var(--gold); }
  .hero-subtitle {
    font-size: .95rem; font-weight: 300;
    color: rgba(240,236,228,.55);
    letter-spacing: .05em; line-height: 1.7;
    max-width: 380px;
    margin-top: 28px;
    opacity: 0;
    animation: fadeUp .8s .75s ease forwards;
  }
  .hero-actions {
    display: flex; gap: 20px; align-items: center;
    margin-top: 48px;
    opacity: 0;
    animation: fadeUp .8s 1s ease forwards;
  }
  .btn-primary {
    font-family: 'Syncopate', sans-serif;
    font-size: .68rem; font-weight: 700; letter-spacing: .2em;
    color: var(--ink);
    background: var(--gold);
    padding: 16px 40px;
    text-decoration: none;
    border: none; cursor: none;
    transition: background .3s, transform .2s, box-shadow .3s;
    display: inline-block;
  }
  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(201,168,76,.3);
  }
  .btn-ghost {
    font-family: 'DM Sans', sans-serif;
    font-size: .8rem; font-weight: 300;
    letter-spacing: .12em;
    color: rgba(240,236,228,.7);
    text-decoration: none;
    display: flex; align-items: center; gap: 10px;
    cursor: none;
    transition: color .3s;
  }
  .btn-ghost:hover { color: var(--bone); }
  .btn-ghost svg { width: 18px; transition: transform .3s; }
  .btn-ghost:hover svg { transform: translateX(4px); }

  .hero-scroll {
    position: absolute; bottom: 40px; left: 60px;
    display: flex; align-items: center; gap: 14px;
    opacity: 0;
    animation: fadeUp .6s 1.4s ease forwards;
  }
  .scroll-line {
    width: 60px; height: 1px;
    background: linear-gradient(to right, var(--gold), transparent);
  }
  .scroll-text {
    font-family: 'Syncopate', sans-serif;
    font-size: .55rem; letter-spacing: .4em; text-transform: uppercase;
    color: rgba(240,236,228,.35);
  }

  /* ── SECTION COMMON ── */
  section { position: relative; z-index: 1; }
  .section-label {
    font-family: 'Syncopate', sans-serif;
    font-size: .58rem; letter-spacing: .45em; text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    display: flex; align-items: center; gap: 14px;
  }
  .section-label::before {
    content: ''; display: block;
    width: 30px; height: 1px; background: var(--gold);
  }
  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 5vw, 5rem);
    font-weight: 300; line-height: 1.05;
    letter-spacing: -.01em;
  }

  /* ── DIVIDER ── */
  .divider {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(201,168,76,.25), transparent);
    margin: 0 60px;
  }

  /* ── FEATURED 3D SHOWCASE ── */
  #showcase {
    padding: 120px 60px;
    background: linear-gradient(to bottom, var(--ink), var(--slate));
  }
  .showcase-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 72px;
  }
  .showcase-header-text { max-width: 500px; }
  .showcase-header p {
    font-size: .9rem; color: rgba(240,236,228,.5);
    line-height: 1.7; margin-top: 16px;
  }
  .showcase-count {
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem; font-weight: 300;
    color: rgba(201,168,76,.12);
    line-height: 1; letter-spacing: -.02em;
  }

  /* 3D CARD GRID */
  .art-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .art-card {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/4;
    background: var(--slate);
    cursor: none;
    group: '';
  }
  .art-card::before {
    content: ''; position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(160deg, transparent 40%, rgba(10,8,6,.85) 100%);
    opacity: .7;
    transition: opacity .5s;
  }
  .art-card:hover::before { opacity: .4; }
  .art-card-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .8s cubic-bezier(.25,.46,.45,.94);
    transform-origin: center;
  }
  .art-card:hover .art-card-img { transform: scale(1.07); }

  /* Painted canvas simulation using CSS */
  .art-canvas {
    width: 100%; height: 100%;
    position: relative;
    overflow: hidden;
    transform: translateZ(0);
  }

  /* 3D tilt effect overlay */
  .art-card-3d {
    transition: transform .4s cubic-bezier(.25,.46,.45,.94), box-shadow .4s;
    transform-style: preserve-3d;
    will-change: transform;
  }
  .art-card-3d:hover {
    box-shadow: 0 30px 80px rgba(0,0,0,.7), 0 0 40px rgba(201,168,76,.1);
  }

  .art-card-info {
    position: absolute; bottom: 0; left: 0; right: 0;
    z-index: 2;
    padding: 32px 28px;
    transform: translateY(12px);
    transition: transform .4s ease;
  }
  .art-card:hover .art-card-info { transform: translateY(0); }
  .art-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.55rem; font-weight: 400; line-height: 1.15;
    margin-bottom: 6px;
  }
  .art-card-artist {
    font-size: .72rem; letter-spacing: .15em;
    color: var(--gold); text-transform: uppercase;
    margin-bottom: 14px;
  }
  .art-card-bottom {
    display: flex; justify-content: space-between; align-items: center;
    opacity: 0; transform: translateY(10px);
    transition: opacity .3s .1s, transform .3s .1s;
  }
  .art-card:hover .art-card-bottom { opacity: 1; transform: translateY(0); }
  .art-card-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; font-weight: 300;
    color: var(--gold-light);
  }
  .art-card-btn {
    font-family: 'Syncopate', sans-serif;
    font-size: .58rem; font-weight: 700; letter-spacing: .18em;
    color: var(--ink); background: var(--gold);
    border: none; padding: 9px 18px;
    cursor: none;
    transition: background .2s, transform .2s;
  }
  .art-card-btn:hover { background: var(--gold-light); transform: scale(1.03); }

  .art-card-featured {
    grid-column: span 2;
    grid-row: span 2;
    aspect-ratio: auto;
  }

  /* Artwork paintings using CSS gradients */
  .painting-1 {
    background:
      radial-gradient(ellipse 80% 60% at 30% 40%, #8b1a1a 0%, transparent 70%),
      radial-gradient(ellipse 60% 80% at 70% 60%, #1a3a5c 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 50% 80%, #2d1b0e 0%, transparent 80%),
      linear-gradient(135deg, #0d0a07 0%, #1a0f0a 40%, #0a1520 100%);
  }
  .painting-2 {
    background:
      radial-gradient(ellipse 70% 50% at 60% 30%, #d4a017 0%, transparent 60%),
      radial-gradient(ellipse 50% 70% at 20% 70%, #8b4513 0%, transparent 70%),
      linear-gradient(180deg, #0e0c08 0%, #1c1408 60%, #0a0906 100%);
  }
  .painting-3 {
    background:
      radial-gradient(circle 200px at 50% 40%, rgba(255,255,255,.15) 0%, transparent 100%),
      radial-gradient(ellipse 90% 60% at 50% 80%, #2c4a3e 0%, transparent 70%),
      linear-gradient(160deg, #080d0b 0%, #0f1e18 100%);
  }
  .painting-4 {
    background:
      radial-gradient(ellipse 60% 40% at 70% 30%, #7c3f8a 0%, transparent 60%),
      radial-gradient(ellipse 80% 60% at 30% 70%, #1a0a2e 0%, transparent 70%),
      radial-gradient(circle 100px at 55% 45%, rgba(255,220,150,.2) 0%, transparent 60%),
      linear-gradient(120deg, #0d0812 0%, #120920 100%);
  }
  .painting-5 {
    background:
      radial-gradient(ellipse 100% 60% at 50% 50%, #c25b1e 0%, transparent 60%),
      radial-gradient(ellipse 50% 80% at 20% 40%, #8a2c10 0%, transparent 70%),
      linear-gradient(160deg, #120604 0%, #1c0d08 100%);
  }
  .painting-6 {
    background:
      conic-gradient(from 45deg at 40% 50%, #0a1520 0deg, #1a3050 60deg, #0a1520 90deg, #0d2030 180deg, #0a1520 270deg, #1a3050 300deg, #0a1520 360deg),
      radial-gradient(ellipse 50% 50% at 50% 50%, rgba(100,180,255,.1) 0%, transparent 60%);
  }

  /* Artistic texture overlay on paintings */
  .art-canvas::after {
    content: '';
    position: absolute; inset: 0;
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
    opacity: .4;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  /* Brushstroke overlays */
  .brush-strokes {
    position: absolute; inset: 0;
    overflow: hidden;
  }
  .brush-strokes::before {
    content: '';
    position: absolute;
    inset: -10%;
    background: repeating-linear-gradient(
      78deg,
      transparent 0px,
      transparent 8px,
      rgba(255,255,255,.012) 8px,
      rgba(255,255,255,.012) 9px
    );
  }

  /* ── 3D VIEWER SECTION ── */
  #viewer {
    padding: 120px 60px;
    background: var(--slate);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .viewer-stage {
    position: relative;
    aspect-ratio: 1;
    display: flex; align-items: center; justify-content: center;
  }
  .viewer-canvas {
    width: 100%; height: 100%;
  }
  #art-viewer-canvas {
    border-radius: 2px;
  }
  .viewer-controls {
    display: flex; gap: 12px;
    margin-top: 20px; justify-content: center;
  }
  .view-btn {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(240,236,228,.2);
    border: none; cursor: none;
    transition: background .2s, transform .2s;
  }
  .view-btn.active { background: var(--gold); transform: scale(1.3); }
  .view-btn:hover { background: rgba(201,168,76,.5); }

  .viewer-info { padding: 20px 0; }
  .viewer-info .section-label { margin-bottom: 28px; }
  .viewer-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    font-weight: 300; line-height: 1.05;
    margin-bottom: 8px;
  }
  .viewer-artist {
    font-size: .78rem; letter-spacing: .2em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 28px;
  }
  .viewer-desc {
    font-size: .9rem; line-height: 1.8;
    color: rgba(240,236,228,.55);
    margin-bottom: 36px;
    font-weight: 300;
  }
  .viewer-meta {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px; background: rgba(201,168,76,.1);
    margin-bottom: 40px;
  }
  .meta-item {
    background: var(--slate);
    padding: 18px 20px;
  }
  .meta-label {
    font-size: .65rem; letter-spacing: .2em; text-transform: uppercase;
    color: rgba(240,236,228,.35); margin-bottom: 6px;
  }
  .meta-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 400;
    color: var(--bone);
  }
  .viewer-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.6rem; font-weight: 300;
    color: var(--gold-light);
    margin-bottom: 28px;
  }
  .viewer-price span {
    font-size: 1rem;
    color: rgba(240,236,228,.35);
    font-family: 'DM Sans', sans-serif;
    margin-left: 8px;
  }
  .viewer-actions { display: flex; gap: 14px; }
  .btn-add-cart {
    flex: 1;
    font-family: 'Syncopate', sans-serif;
    font-size: .65rem; font-weight: 700; letter-spacing: .18em;
    color: var(--ink); background: var(--gold);
    border: none; padding: 18px;
    cursor: none;
    transition: background .3s, transform .2s, box-shadow .3s;
  }
  .btn-add-cart:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(201,168,76,.3);
  }
  .btn-wishlist {
    width: 56px;
    background: rgba(201,168,76,.08);
    border: 1px solid rgba(201,168,76,.2);
    color: var(--gold);
    display: flex; align-items: center; justify-content: center;
    cursor: none;
    transition: background .3s, border-color .3s;
  }
  .btn-wishlist:hover {
    background: rgba(201,168,76,.15);
    border-color: var(--gold);
  }

  /* ── ARTISTS ── */
  #artists {
    padding: 120px 60px;
    background: linear-gradient(to bottom, var(--slate), var(--ink));
  }
  .artists-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 60px;
  }
  .artist-card {
    position: relative; overflow: hidden;
    aspect-ratio: 2/3;
    background: #111;
    cursor: none;
  }
  .artist-portrait {
    width: 100%; height: 100%;
    position: relative;
    transition: transform .6s cubic-bezier(.25,.46,.45,.94);
  }
  .artist-card:hover .artist-portrait { transform: scale(1.06); }
  .portrait-1 {
    background: radial-gradient(ellipse 60% 80% at 50% 30%, #3d2b1f 0%, #1a0e08 60%, #0a0605 100%);
  }
  .portrait-2 {
    background: radial-gradient(ellipse 60% 80% at 50% 30%, #1f2d3d 0%, #0e1a28 60%, #050a10 100%);
  }
  .portrait-3 {
    background: radial-gradient(ellipse 60% 80% at 50% 30%, #2b3d1f 0%, #151f0e 60%, #080a05 100%);
  }
  .portrait-4 {
    background: radial-gradient(ellipse 60% 80% at 50% 30%, #3d1f3d 0%, #1a0e1a 60%, #0a050a 100%);
  }
  /* Silhouette figure */
  .artist-figure {
    position: absolute;
    bottom: 0; left: 50%; transform: translateX(-50%);
    width: 55%;
  }
  .artist-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,8,6,.95) 0%, transparent 50%);
  }
  .artist-info {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 28px 24px;
    z-index: 2;
  }
  .artist-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem; font-weight: 400;
    margin-bottom: 4px;
  }
  .artist-specialty {
    font-size: .7rem; letter-spacing: .18em; text-transform: uppercase;
    color: var(--gold);
  }
  .artist-works {
    font-size: .75rem;
    color: rgba(240,236,228,.4);
    margin-top: 6px;
    opacity: 0; transform: translateY(6px);
    transition: opacity .3s, transform .3s;
  }
  .artist-card:hover .artist-works { opacity: 1; transform: translateY(0); }

  /* ── PROCESS / ABOUT ── */
  #about {
    padding: 120px 60px;
    background: var(--ink);
    display: grid;
    grid-template-columns: 5fr 4fr;
    gap: 100px;
    align-items: center;
  }
  .about-visual {
    position: relative;
    aspect-ratio: 1;
  }
  .about-canvas-wrap {
    position: relative; width: 100%; height: 100%;
  }
  .about-text .section-label { margin-bottom: 28px; }
  .about-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 4vw, 4.5rem);
    font-weight: 300; line-height: 1.05;
    margin-bottom: 32px;
  }
  .about-body {
    font-size: .9rem; line-height: 1.9;
    color: rgba(240,236,228,.5);
    margin-bottom: 20px;
  }
  .about-stats {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 32px; margin-top: 48px;
  }
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem; font-weight: 300;
    color: var(--gold-light);
    line-height: 1;
  }
  .stat-label {
    font-size: .72rem; letter-spacing: .12em; text-transform: uppercase;
    color: rgba(240,236,228,.4); margin-top: 6px;
  }

  /* ── NEWSLETTER ── */
  #newsletter {
    padding: 100px 60px;
    background: var(--slate);
    text-align: center;
  }
  .newsletter-wrap { max-width: 560px; margin: 0 auto; }
  .newsletter-wrap .section-label { justify-content: center; }
  .newsletter-wrap .section-label::before { display: none; }
  .newsletter-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 4vw, 4rem);
    font-weight: 300; line-height: 1.1;
    margin-bottom: 16px;
  }
  .newsletter-sub {
    font-size: .88rem; color: rgba(240,236,228,.45);
    line-height: 1.7; margin-bottom: 40px;
  }
  .newsletter-form {
    display: flex; gap: 0;
    background: rgba(201,168,76,.06);
    border: 1px solid rgba(201,168,76,.15);
  }
  .newsletter-input {
    flex: 1;
    background: none; border: none;
    padding: 16px 22px;
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem; font-weight: 300;
    color: var(--bone);
    outline: none;
  }
  .newsletter-input::placeholder { color: rgba(240,236,228,.3); }
  .newsletter-submit {
